<?xml version="1.0" encoding="utf-8"?>
<!--
    Screen displaying a filterable history of all expenses.
    Includes date pickers for range selection and a RecyclerView for the list.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_cream">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expense History"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginBottom="12dp"/>

    <!-- Filter Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Start Date Selector -->
        <Button
            android:id="@+id/btnFilterStart"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="4dp"/>

        <!-- End Date Selector -->
        <Button
            android:id="@+id/btnFilterEnd"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="4dp"/>

        <!-- Apply Filter Button -->
        <Button
            android:id="@+id/btnApplyFilter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Filter"
            android:textSize="12sp"
            android:backgroundTint="@color/primary_green"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- Empty State Placeholder -->
    <TextView
        android:id="@+id/tvEmptyList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No expenses found for this period."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Main Expense List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExpenses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
