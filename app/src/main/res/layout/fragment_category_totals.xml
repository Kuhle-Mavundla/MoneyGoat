<?xml version="1.0" encoding="utf-8"?>
<!--
    Screen showing spending breakdown by category.
    Displays categorical totals and a grand total for a selected date range.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_cream">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category Totals"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginBottom="12dp"/>

    <!-- Filter Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Start Date Filter -->
        <Button
            android:id="@+id/btnCatFilterStart"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="4dp"/>

        <!-- End Date Filter -->
        <Button
            android:id="@+id/btnCatFilterEnd"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="4dp"/>

        <!-- Apply Button -->
        <Button
            android:id="@+id/btnCatApplyFilter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Filter"
            android:textSize="12sp"
            android:backgroundTint="@color/primary_green"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- Overall Sum for the period -->
    <TextView
        android:id="@+id/tvGrandTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: R 0.00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Empty State Text -->
    <TextView
        android:id="@+id/tvEmptyCat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No data for this period."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- List of Category Totals -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryTotals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
