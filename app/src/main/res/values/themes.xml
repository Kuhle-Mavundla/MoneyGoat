<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.MoneyGoat" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_gold</item>

        <!-- Background and Text -->
        <item name="android:windowBackground">@color/background_cream</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_green_dark</item>
    </style>
</resources>
